{
  "name": "query-connector",
  "description": "DIBBs Query Connector: a Next.js full-stack application for public health staff to query healthcare organizations for patient records via FHIR and TEFCA networks.",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "docker compose -f docker-compose-dev.yaml up -d && next dev --turbopack; docker compose -f docker-compose-dev.yaml down --remove-orphans",
    "dev-win": "start docker compose -f docker-compose-dev.yaml up && next dev",
    "dev:db": "docker compose -f docker-compose-dev.yaml up",
    "dev:next": "npx dotenv -e ./.env -- next dev",
    "setup-local-env": "./setup-env.sh",
    "build": "next build && cp -r .next/static .next/standalone/.next && cp -r public .next/standalone/",
    "start": "NODE_TLS_REJECT_UNAUTHORIZED=0 node .next/standalone/server.js",
    "lint": "npx eslint -c eslint.config.mjs src --fix",
    "test": "npm run test:unit && npm run test:integration",
    "test:ci": " bash ./setup-scripts/unit_and_integration_tests.sh",
    "test:unit": "TEST_TYPE='unit' jest --testPathIgnorePatterns='/e2e/' '/integration/'",
    "test:unit:file": "npm run test:unit -- --testPathPatterns",
    "test:unit:watch": "jest --watch",
    "test:update": "jest --updateSnapshot --testPathIgnorePatterns=/e2e/",
    "test:integration": "JUST_INTEGRATION=true bash ./setup-scripts/unit_and_integration_tests.sh",
    "test:playwright": "bash ./setup-scripts/e2e_tests.sh",
    "test:playwright:ui": "bash ./setup-scripts/e2e_tests_local.sh"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1081.0",
    "@axe-core/playwright": "^4.12.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.10",
    "@scalar/nextjs-api-reference": "^0.11.8",
    "@trussworks/react-uswds": "^11.1.0",
    "@types/mdx": "^2.0.14",
    "@uswds/uswds": "^3.13.0",
    "base-64": "^1.0.0",
    "classnames": "^2.5.1",
    "csv-parse": "^6.1.0",
    "date-fns": "^4.4.0",
    "fhirpath": "^4.11.0",
    "jose": "^5.2.2",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.30",
    "next-nprogress-bar": "^2.4.4",
    "node-hl7-client": "^3.0.0",
    "pg": "^8.22.0",
    "pg-promise": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-highlight-words": "^0.21.0",
    "react-idle-timer": "^5.7.3",
    "react-loading-skeleton": "^3.5.0",
    "react-toastify": "^10.0.5",
    "request-mocking-protocol": "^0.4.0",
    "sharp": "^0.35.3",
    "undici": "^7.28.0"
  },
  "overrides": {
    "fast-xml-parser": "^5.5.6",
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@smithy/util-stream": "^4.7.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/base-64": "^1.0.2",
    "@types/fhir": "^0.0.44",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-highlight-words": "^0.20.1",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^54.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "focus-trap-react": "^11.0.6",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-extended": "^4.0.2",
    "jest-fixed-jsdom": "^0.0.11",
    "postcss": "^8",
    "prettier": "3.9.4",
    "sass": "^1.101.0",
    "sass-embedded": "^1.100.0",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0"
  }
}
