FROM alpine:latest

# Install curl, PostgreSQL client, and jq (used to inspect FHIR batch responses)
RUN apk add --no-cache curl postgresql-client bash jq

# Copy the script
COPY ./setup-scripts/seed_aidbox.sh /seed_aidbox.sh
RUN chmod +x /seed_aidbox.sh

# Create data directory
RUN mkdir /data

ENTRYPOINT ["/bin/bash", "-c"]
CMD ["/seed_aidbox.sh $AIDBOX_BASE_URL $APP_HOSTNAME"]